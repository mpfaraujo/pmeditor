# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

#zip files
*.zip

# Windows reserved names
nul
teste.yaml

.vercel

/php/

# provas (PDFs e .tex gerados — não versionar)
/scripts/

# fila de importação e relatórios gerados pelo pipeline (arquivos temporários)
/public/data/import-queue.json
/public/data/import-queue-*.json
/public/data/import-queue-*.manifest.json
/public/data/import-report-*.json

# arquivos temporários de trabalho (imagens, htmls, jsons de debug)
tmp_*
tmp-*

# instaladores e executáveis avulsos
*.msi

# diário de bordo compartilhado entre agentes (Claude + GPT) — local only
/AGENTS.md

/.venv/

scripts/tmp/
